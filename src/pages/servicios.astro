---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTASection from "@components/CTASection.astro";
import ServiceCard from "@components/ServiceCard.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { services } from "@data/services";
import { site } from "@data/site";
import { breadcrumbSchema, legalServiceSchema } from "@utils/schema";
import { buildCanonical } from "@utils/seo";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Servicios" }
];

const schema = [
  legalServiceSchema(),
  breadcrumbSchema([
    { name: "Inicio", url: buildCanonical("/") },
    { name: "Servicios", url: buildCanonical("/servicios") }
  ])
];
---

<MainLayout
  title="Servicios legales"
  description="Áreas de práctica de Cancino Abogados: derecho civil, comercial, inmobiliario y laboral para personas y empresas."
  path="/servicios"
  schema={schema}
>
  <section class="bg-mist py-14">
    <div class="container-page">
      <Breadcrumbs items={breadcrumbs} />
      <h1 class="mt-6 font-serif text-4xl font-semibold text-night sm:text-5xl">Servicios legales</h1>
      <p class="section-copy">
        Asesoría jurídica personalizada para revisar antecedentes, prevenir riesgos y definir una estrategia adecuada al caso.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="container-page grid gap-5 md:grid-cols-2">
      {services.map((service) => (
        <ServiceCard title={service.title} summary={service.summary} href={`/servicios/${service.slug}`} />
      ))}
    </div>
  </section>

  <CTASection title="¿Necesitas orientación legal?" text={`Escríbenos a ${site.email} o agenda una consulta por WhatsApp.`} />
</MainLayout>
