---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTASection from "@components/CTASection.astro";
import FAQ from "@components/FAQ.astro";
import ProcessSteps from "@components/ProcessSteps.astro";
import ServiceCard from "@components/ServiceCard.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { services, type Service } from "@data/services";
import { breadcrumbSchema, faqPageSchema, legalServiceSchema } from "@utils/schema";
import { buildCanonical } from "@utils/seo";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props as { service: Service };
const related = services.filter((item) => item.slug !== service.slug).slice(0, 3);
const path = `/servicios/${service.slug}`;
const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios" },
  { label: service.title }
];
const schema = [
  legalServiceSchema(),
  faqPageSchema(service.faqs),
  breadcrumbSchema([
    { name: "Inicio", url: buildCanonical("/") },
    { name: "Servicios", url: buildCanonical("/servicios") },
    { name: service.title, url: buildCanonical(path) }
  ])
];
---

<MainLayout
  title={`${service.title} en Chile`}
  description={`${service.value} Cancino Abogados entrega asesoría en ${service.title.toLowerCase()} para personas y empresas.`}
  path={path}
  schema={schema}
>
  <section class="bg-mist py-14">
    <div class="container-page">
      <Breadcrumbs items={breadcrumbs} />
      <h1 class="mt-6 max-w-4xl font-serif text-4xl font-semibold text-night sm:text-5xl">
        {service.title}
      </h1>
      <p class="section-copy">{service.value}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="btn-primary" href="https://wa.me/56956075464" target="_blank" rel="noreferrer">Consultar por WhatsApp</a>
        <a class="btn-outline" href="/contacto">Solicitar contacto</a>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-page grid gap-12 lg:grid-cols-[0.72fr_0.28fr]">
      <article>
        <h2 class="font-serif text-3xl font-semibold text-night">Descripción del área</h2>
        <p class="mt-5 text-base leading-8 text-slate-600">{service.description}</p>

        <div class="mt-12 grid gap-8 md:grid-cols-2">
          <section>
            <h2 class="font-serif text-2xl font-semibold text-night">Cuándo necesitas este servicio</h2>
            <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-600">
              {service.needs.map((item) => <li class="border-l-2 border-gold pl-4">{item}</li>)}
            </ul>
          </section>

          <section>
            <h2 class="font-serif text-2xl font-semibold text-night">Cómo podemos ayudarte</h2>
            <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-600">
              {service.help.map((item) => <li class="border-l-2 border-gold pl-4">{item}</li>)}
            </ul>
          </section>
        </div>

        <section class="mt-12 rounded-md bg-mist p-7">
          <h2 class="font-serif text-2xl font-semibold text-night">Documentos o antecedentes recomendados</h2>
          <ul class="mt-5 grid gap-3 text-sm leading-7 text-slate-600 md:grid-cols-2">
            {service.documents.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="mt-12">
          <h2 class="font-serif text-2xl font-semibold text-night">Proceso de atención</h2>
          <div class="mt-6">
            <ProcessSteps />
          </div>
        </section>

        <section class="mt-12">
          <h2 class="font-serif text-2xl font-semibold text-night">Preguntas frecuentes del servicio</h2>
          <div class="mt-6">
            <FAQ items={service.faqs} />
          </div>
        </section>
      </article>

      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="rounded-md border border-slate-200 bg-white p-6 shadow-soft">
          <h2 class="font-serif text-xl font-semibold text-night">Consulta inicial</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            Comparte tus antecedentes y recibe orientación sobre los pasos posibles.
          </p>
          <a class="btn-primary mt-5 w-full" href="https://wa.me/56956075464" target="_blank" rel="noreferrer">WhatsApp</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="bg-mist py-20">
    <div class="container-page">
      <p class="eyebrow">Servicios relacionados</p>
      <h2 class="section-title">Otras áreas de práctica</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {related.map((item) => (
          <ServiceCard title={item.title} summary={item.summary} href={`/servicios/${item.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</MainLayout>
