---
import AttorneyProfile from "@components/AttorneyProfile.astro";
import CTASection from "@components/CTASection.astro";
import FAQSection from "@components/FAQSection.astro";
import Hero from "@components/Hero.astro";
import LocationCard from "@components/LocationCard.astro";
import ProcessSteps from "@components/ProcessSteps.astro";
import ReviewCard from "@components/ReviewCard.astro";
import ServiceCard from "@components/ServiceCard.astro";
import TrustSection from "@components/TrustSection.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { faqs } from "@data/faqs";
import { locations } from "@data/locations";
import { reviews } from "@data/reviews";
import { services } from "@data/services";
import { site } from "@data/site";
import { attorneySchema, faqPageSchema, legalServiceSchema, localBusinessSchema } from "@utils/schema";

const schema = [legalServiceSchema(), localBusinessSchema(), attorneySchema(), faqPageSchema(faqs)];
---

<MainLayout
  title="Asesoría legal estratégica para empresas y personas"
  description="Cancino Abogados entrega asesoría legal estratégica para empresas y personas en San Felipe, Los Andes y Viña del Mar."
  path="/"
  schema={schema}
>
  <Hero />

  <section class="py-20 lg:py-24">
    <div class="container-page">
      <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
        <div>
          <p class="eyebrow">Servicios principales</p>
          <h2 class="section-title">Áreas de práctica orientadas a decisiones concretas</h2>
        </div>
        <p class="text-base leading-8 text-slate-600 lg:max-w-2xl">
          Cada servicio está pensado para ayudarle a identificar riesgos, ordenar antecedentes y tomar decisiones legales con mayor claridad.
        </p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <ServiceCard title={service.title} summary={service.summary} href={`/${service.slug}/`} />
        ))}
      </div>
    </div>
  </section>

  <AttorneyProfile />

  <section class="py-20 lg:py-24">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="eyebrow">Atención local</p>
        <h2 class="section-title">Abogados en San Felipe, Los Andes y Viña del Mar</h2>
        <p class="section-copy">
          La asesoría puede coordinarse para clientes que requieren orientación legal local, revisión documental o acompañamiento estratégico en materias civiles, comerciales, inmobiliarias y laborales para empleadores.
        </p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {locations.map((location) => (
          <LocationCard city={location.city} summary={location.summary} href={`/${location.slug}/`} />
        ))}
      </div>
    </div>
  </section>

  <TrustSection />

  <section class="py-20 lg:py-24">
    <div class="container-page">
      <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
        <div>
          <p class="eyebrow">Proceso de atención</p>
          <h2 class="section-title">Un método claro desde la primera conversación</h2>
        </div>
        <p class="section-copy">
          La asesoría busca reducir incertidumbre: primero entendemos el problema, luego evaluamos alternativas y finalmente definimos una ruta de acción proporcional al caso.
        </p>
      </div>
      <div class="mt-12">
        <ProcessSteps />
      </div>
    </div>
  </section>

  <section class="bg-mist py-20 lg:py-24">
    <div class="container-page">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="eyebrow">Testimonios</p>
          <h2 class="section-title">Experiencias de clientes</h2>
        </div>
        <p class="max-w-xl text-sm leading-7 text-slate-500">
          Testimonios referenciales y simulados para fines de maqueta visual. No corresponden a resultados garantizados ni a casos reales identificables.
        </p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {reviews.map((review) => (
          <ReviewCard {...review} />
        ))}
      </div>
    </div>
  </section>

  <FAQSection />

  <CTASection
    title="Solicite una evaluación legal"
    text={`Escríbanos a ${site.email} o coordine una consulta para revisar sus antecedentes y próximos pasos.`}
  />
</MainLayout>
