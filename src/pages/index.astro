---
import CTASection from "@components/CTASection.astro";
import FAQ from "@components/FAQ.astro";
import Hero from "@components/Hero.astro";
import ProcessSteps from "@components/ProcessSteps.astro";
import ReviewCard from "@components/ReviewCard.astro";
import ServiceCard from "@components/ServiceCard.astro";
import TrustSection from "@components/TrustSection.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { faqs } from "@data/faqs";
import { reviews } from "@data/reviews";
import { services } from "@data/services";
import { site } from "@data/site";
import { attorneySchema, faqPageSchema, legalServiceSchema } from "@utils/schema";

const schema = [legalServiceSchema(), attorneySchema(), faqPageSchema(faqs)];
---

<MainLayout
  description={site.description}
  path="/"
  schema={schema}
>
  <Hero />

  <section class="py-20 lg:py-24">
    <div class="container-page">
      <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
        <div>
          <p class="eyebrow">Áreas de práctica</p>
          <h2 class="section-title">Asesoría legal para personas y empresas</h2>
        </div>
        <p class="text-base leading-8 text-slate-600 lg:max-w-2xl">
          Servicios jurídicos orientados a prevenir conflictos, ordenar decisiones relevantes y acompañar procesos legales con criterios claros, documentación precisa y comunicación permanente.
        </p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((service) => (
          <ServiceCard title={service.title} summary={service.summary} href={`/servicios/${service.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <section class="bg-mist py-20 lg:py-24">
    <div class="container-page grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div class="relative overflow-hidden rounded-md bg-night p-8 text-white shadow-[0_24px_80px_rgba(7,26,36,0.18)] sm:p-10">
        <div class="absolute right-0 top-0 h-40 w-40 bg-gold/10 blur-3xl"></div>
        <div class="relative">
          <p class="eyebrow">Autoridad profesional</p>
          <h2 class="mt-3 font-serif text-4xl font-semibold">Saúl Cancino</h2>
          <p class="mt-5 text-base leading-8 text-white/72">
            Abogado por la Universidad de Valparaíso y Magíster en Derecho, mención Derecho de la Empresa, LL.M. UC.
          </p>
          <div class="mt-8 grid gap-4 sm:grid-cols-3">
            <div class="rounded-md border border-white/10 bg-white/[0.06] p-4">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">Formación</p>
              <p class="mt-2 text-sm leading-6 text-white/80">Universidad de Valparaíso</p>
            </div>
            <div class="rounded-md border border-white/10 bg-white/[0.06] p-4">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">Reconocimiento</p>
              <p class="mt-2 text-sm leading-6 text-white/80">Mejor Licenciado 2014</p>
            </div>
            <div class="rounded-md border border-white/10 bg-white/[0.06] p-4">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">Idiomas</p>
              <p class="mt-2 text-sm leading-6 text-white/80">Español e inglés</p>
            </div>
          </div>
          <a class="btn-primary mt-8" href="/abogado-saul-cancino">Conocer perfil profesional</a>
        </div>
      </div>
      <div>
        <p class="eyebrow">Enfoque</p>
        <h2 class="section-title">Rigor técnico con comunicación cercana</h2>
        <p class="section-copy">
          La asesoría se construye desde los antecedentes concretos del cliente: revisión documental, identificación de riesgos, alternativas razonables y definición de próximos pasos. Sin promesas de resultado, con foco en estrategia, prevención y acompañamiento.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {["Análisis jurídico claro antes de decidir.", "Orden documental para reducir incertidumbre.", "Atención personalizada en cada etapa.", "Mirada preventiva para personas y empresas."].map((item) => (
            <div class="rounded-md border border-slate-200 bg-white p-5 text-sm font-semibold leading-7 text-petroleum shadow-soft">
              {item}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <TrustSection />

  <section class="py-20 lg:py-24">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="eyebrow">Proceso de atención</p>
        <h2 class="section-title">Un método claro desde la primera conversación</h2>
        <p class="section-copy">
          Cada consulta se aborda con una secuencia simple: entender el caso, ordenar antecedentes y definir una ruta de acción proporcional al objetivo.
        </p>
      </div>
      <div class="mt-10">
        <ProcessSteps />
      </div>
    </div>
  </section>

  <section class="bg-mist py-20 lg:py-24">
    <div class="container-page">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="eyebrow">Testimonios</p>
          <h2 class="section-title">Experiencias de clientes</h2>
        </div>
        <p class="max-w-xl text-sm leading-7 text-slate-500">
          Testimonios referenciales y simulados para fines de maqueta visual. No corresponden a resultados garantizados ni a casos reales identificables.
        </p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {reviews.map((review) => (
          <ReviewCard {...review} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-24">
    <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Preguntas frecuentes</p>
        <h2 class="section-title">Dudas habituales antes de consultar</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTASection />
</MainLayout>
