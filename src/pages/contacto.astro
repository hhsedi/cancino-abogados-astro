---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ContactForm from "@components/ContactForm.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { site } from "@data/site";
import { breadcrumbSchema, legalServiceSchema, localBusinessSchema } from "@utils/schema";
import { buildCanonical } from "@utils/seo";

const schema = [
  legalServiceSchema(),
  localBusinessSchema(),
  breadcrumbSchema([
    { name: "Inicio", url: buildCanonical("/") },
    { name: "Contacto", url: buildCanonical("/contacto/") }
  ])
];

const contactItems = [
  {
    label: "WhatsApp",
    value: site.phone,
    href: site.whatsapp,
    helper: "Respuesta directa para coordinar una consulta."
  },
  {
    label: "Correo",
    value: site.email,
    href: site.emailHref,
    helper: "Ideal para enviar antecedentes y documentos."
  },
  {
    label: "Ubicaciones",
    value: site.locations.join(" · "),
    href: undefined,
    helper: "Atención vinculada a San Felipe, Los Andes y Viña del Mar."
  }
];
---

<MainLayout
  title="Contacto"
  description="Contacte a Cancino Abogados por WhatsApp, teléfono o correo. Atención legal en San Felipe, Los Andes y Viña del Mar."
  path="/contacto/"
  schema={schema}
>
  <section class="bg-mist py-14">
    <div class="container-page">
      <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Contacto" }]} />
      <h1 class="mt-6 font-serif text-4xl font-semibold text-night sm:text-5xl">Contacto</h1>
      <p class="section-copy">
        Cuéntenos brevemente su situación y comparta los antecedentes disponibles para coordinar una orientación inicial.
      </p>
    </div>
  </section>

  <section class="py-20 lg:py-24">
    <div class="container-page grid gap-10 lg:grid-cols-[0.82fr_1.18fr]">
      <aside class="space-y-5">
        <div class="rounded-md bg-night p-8 text-white shadow-[0_24px_80px_rgba(7,26,36,0.18)]">
          <p class="eyebrow">Contacto directo</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold">Agendar una consulta</h2>
          <p class="mt-4 text-sm leading-7 text-white/70">
            Para una revisión eficiente, envíe una breve descripción del caso y los documentos principales disponibles.
          </p>
          <a class="btn-primary mt-8 w-full" href={site.whatsapp} target="_blank" rel="noreferrer">Contactar por WhatsApp</a>
        </div>

        <div class="grid gap-4">
          {contactItems.map((item) => (
            <div class="rounded-md border border-slate-200 bg-white p-5 shadow-soft">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">{item.label}</p>
              {item.href ? (
                <a class="mt-2 block font-semibold text-petroleum hover:text-gold" href={item.href} target={item.label === "WhatsApp" ? "_blank" : undefined} rel={item.label === "WhatsApp" ? "noreferrer" : undefined}>
                  {item.value}
                </a>
              ) : (
                <p class="mt-2 font-semibold text-petroleum">{item.value}</p>
              )}
              <p class="mt-2 text-sm leading-6 text-slate-500">{item.helper}</p>
            </div>
          ))}
        </div>
      </aside>

      <ContactForm />
    </div>
  </section>
</MainLayout>
