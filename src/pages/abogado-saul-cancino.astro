---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTASection from "@components/CTASection.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { site } from "@data/site";
import { attorneySchema, breadcrumbSchema } from "@utils/schema";
import { buildCanonical } from "@utils/seo";

const schema = [
  attorneySchema(),
  breadcrumbSchema([
    { name: "Inicio", url: buildCanonical("/") },
    { name: "Abogado Saúl Cancino", url: buildCanonical("/abogado-saul-cancino") }
  ])
];
---

<MainLayout
  title="Abogado Saúl Cancino"
  description="Perfil profesional de Saúl Cancino, abogado por la Universidad de Valparaíso y Magíster en Derecho, mención Derecho de la Empresa, LL.M. UC."
  path="/abogado-saul-cancino"
  schema={schema}
>
  <section class="bg-mist py-14">
    <div class="container-page">
      <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Abogado Saúl Cancino" }]} />
      <h1 class="mt-6 font-serif text-4xl font-semibold text-night sm:text-5xl">Abogado Saúl Cancino</h1>
      <p class="section-copy">
        Asesoría personalizada, eficiente, rigurosa y comprometida para personas y empresas.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <aside class="rounded-md bg-night p-8 text-white shadow-soft">
        <p class="eyebrow">Perfil</p>
        <h2 class="mt-3 font-serif text-3xl font-semibold">{site.lawyer.name}</h2>
        <p class="mt-5 text-sm leading-7 text-white/75">{site.lawyer.education}</p>
        <p class="mt-5 text-sm font-semibold text-gold">{site.lawyer.recognition}</p>
      </aside>

      <div class="space-y-10">
        <section>
          <h2 class="font-serif text-3xl font-semibold text-night">Formación académica</h2>
          <div class="mt-6 grid gap-4">
            <div class="rounded-md border border-slate-200 p-6">
              <h3 class="font-semibold text-night">Universidad de Valparaíso</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600">Abogado por la Universidad de Valparaíso, Chile. Reconocido como Mejor Licenciado el año 2014.</p>
            </div>
            <div class="rounded-md border border-slate-200 p-6">
              <h3 class="font-semibold text-night">Pontificia Universidad Católica de Chile</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600">Magíster en Derecho, mención Derecho de la Empresa, LL.M. UC.</p>
            </div>
          </div>
        </section>

        <section>
          <h2 class="font-serif text-3xl font-semibold text-night">Idiomas y atención</h2>
          <p class="mt-5 text-base leading-8 text-slate-600">
            Atiende en español e inglés, con una comunicación clara y orientada a que cada cliente comprenda sus alternativas antes de decidir.
          </p>
        </section>

        <section>
          <h2 class="font-serif text-3xl font-semibold text-night">Enfoque profesional</h2>
          <p class="mt-5 text-base leading-8 text-slate-600">
            Su trabajo combina análisis jurídico, orden documental y acompañamiento estratégico, evitando promesas de resultado y priorizando una asesoría honesta, preventiva y responsable.
          </p>
        </section>
      </div>
    </div>
  </section>

  <CTASection title="Agenda una consulta legal" />
</MainLayout>
