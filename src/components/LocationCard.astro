---
type Props = {
  city: string;
  summary: string;
  href: string;
};

const { city, summary, href } = Astro.props;
---

<article class="group rounded-md border border-slate-200 bg-white p-6 shadow-soft transition hover:-translate-y-1 hover:border-gold/70">
  <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">Atención local</p>
  <h3 class="mt-4 font-serif text-2xl font-semibold text-night">Abogado en {city}</h3>
  <p class="mt-4 text-sm leading-7 text-slate-600">{summary}</p>
  <a class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-petroleum group-hover:text-gold" href={href}>
    Ver landing local <span aria-hidden="true">→</span>
  </a>
</article>
