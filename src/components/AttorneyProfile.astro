---
import { site } from "@data/site";
---

<section class="bg-mist py-20 lg:py-24">
  <div class="container-page grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div class="relative overflow-hidden rounded-md bg-night p-6 text-white shadow-[0_24px_80px_rgba(7,26,36,0.18)] sm:p-8">
      <div class="aspect-[4/5] overflow-hidden rounded-md border border-white/10 bg-white/[0.06]">
        <div class="flex h-full items-center justify-center p-8 text-center">
          <div>
            <p class="font-serif text-4xl font-semibold text-gold">SC</p>
            <p class="mt-4 text-sm leading-7 text-white/65">
              Placeholder temporal para fotografía profesional de Saúl Cancino.
            </p>
          </div>
        </div>
      </div>
      <!-- Reemplazar este bloque por src/assets/images/saul-cancino.jpg cuando la foto profesional esté disponible. -->
    </div>

    <div>
      <p class="eyebrow">Cancino Abogados</p>
      <h2 class="section-title">Asesoría clara, estratégica y orientada a decisiones</h2>
      <p class="section-copy">
        {site.lawyer.name} dirige Cancino Abogados con foco en prevención de riesgos legales, estructuración jurídica de negocios y resolución eficiente de conflictos.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        <div class="premium-panel p-5">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">Formación</p>
          <p class="mt-3 text-sm leading-7 text-slate-700">Universidad de Valparaíso</p>
        </div>
        <div class="premium-panel p-5">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">Postgrado</p>
          <p class="mt-3 text-sm leading-7 text-slate-700">Magíster en Derecho de la Empresa UC</p>
        </div>
        <div class="premium-panel p-5">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">Idiomas</p>
          <p class="mt-3 text-sm leading-7 text-slate-700">Español e inglés</p>
        </div>
      </div>
      <a class="btn-primary mt-8" href="/contacto/">Agendar una consulta</a>
    </div>
  </div>
</section>
