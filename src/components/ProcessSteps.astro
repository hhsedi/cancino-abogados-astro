---
const steps = [
  {
    title: "Consulta inicial",
    text: "Revisión del contexto, objetivos y antecedentes disponibles."
  },
  {
    title: "Diagnóstico jurídico",
    text: "Identificación de riesgos, alternativas y próximos pasos razonables."
  },
  {
    title: "Estrategia y ejecución",
    text: "Preparación de documentos, negociación o acciones aplicables según el caso."
  }
];
---

<div class="grid gap-5 md:grid-cols-3">
  {steps.map((step, index) => (
    <article class="rounded-md border border-slate-200 bg-white p-6 shadow-soft">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-petroleum text-sm font-semibold text-white">
        {index + 1}
      </span>
      <h3 class="mt-5 font-serif text-xl font-semibold text-night">{step.title}</h3>
      <p class="mt-3 text-sm leading-7 text-slate-600">{step.text}</p>
    </article>
  ))}
</div>
