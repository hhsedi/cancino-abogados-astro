---
const steps = [
  {
    title: "Cuéntenos su situación",
    text: "Recibimos el contexto inicial, los documentos disponibles y el objetivo que necesita resolver."
  },
  {
    title: "Revisamos opciones legales",
    text: "Ordenamos antecedentes, identificamos riesgos y explicamos alternativas con lenguaje claro."
  },
  {
    title: "Definimos próximos pasos",
    text: "Proponemos una estrategia razonable: prevención, negociación, redacción documental o defensa."
  }
];
---

<div class="overflow-hidden rounded-md border border-slate-200 bg-white shadow-soft">
  <div class="grid md:grid-cols-3">
    {steps.map((step, index) => (
      <article class="relative border-b border-slate-200 p-6 last:border-b-0 md:border-b-0 md:border-r md:last:border-r-0 lg:p-8">
        <span class="text-xs font-bold uppercase tracking-[0.22em] text-gold">Paso {index + 1}</span>
        <h3 class="mt-4 font-serif text-2xl font-semibold leading-tight text-night">{step.title}</h3>
        <p class="mt-4 text-sm leading-7 text-slate-600">{step.text}</p>
      </article>
    ))}
  </div>
</div>
