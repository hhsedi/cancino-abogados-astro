---
const steps = [
  {
    title: "Cuéntenos su situación",
    text: "Recibimos el contexto inicial, los documentos disponibles y el objetivo que necesita resolver."
  },
  {
    title: "Revisamos opciones legales",
    text: "Ordenamos antecedentes, identificamos riesgos y explicamos alternativas con lenguaje claro."
  },
  {
    title: "Definimos próximos pasos",
    text: "Proponemos una estrategia razonable: prevención, negociación, redacción documental o defensa."
  }
];
---

<div class="grid gap-5 md:grid-cols-3">
  {steps.map((step, index) => (
    <article class="rounded-md border border-slate-200 bg-white p-6 shadow-soft transition hover:border-gold/60 lg:p-7">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-petroleum text-sm font-bold text-white">
        {index + 1}
      </span>
      <p class="mt-5 text-xs font-bold uppercase tracking-[0.2em] text-gold">Paso {index + 1}</p>
      <h3 class="mt-3 font-serif text-2xl font-semibold leading-tight text-night">{step.title}</h3>
      <p class="mt-4 text-sm leading-7 text-slate-600">{step.text}</p>
    </article>
  ))}
</div>
