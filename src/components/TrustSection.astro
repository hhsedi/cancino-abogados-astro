---
import { site } from "@data/site";
---

<section class="bg-mist py-16">
  <div class="container-page grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div>
      <p class="eyebrow">Por qué elegir el estudio</p>
      <h2 class="section-title">{site.promise}</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      {["Alto estándar técnico aplicado a problemas reales.", "Rigor en el análisis de antecedentes.", "Comunicación clara para tomar decisiones."].map((item) => (
        <div class="rounded-md bg-white p-5 text-sm leading-7 text-slate-700 shadow-soft">{item}</div>
      ))}
    </div>
  </div>
</section>
