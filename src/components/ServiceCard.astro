---
type Props = {
  title: string;
  summary: string;
  href: string;
};

const { title, summary, href } = Astro.props;

const iconPaths: Record<string, string[]> = {
  "Derecho inmobiliario": ["M4 11.5 12 5l8 6.5", "M6.5 10.5V19h11v-8.5", "M10 19v-5h4v5"],
  "Litigación civil y comercial": ["M12 4v16", "M6 8h12", "M7 8l-3 6h6L7 8Z", "M17 8l-3 6h6l-3-6Z"],
  "Defensa laboral para empleadores": ["M7 8h10v11H7z", "M9 8V6h6v2", "M9.5 12h5", "M9.5 15h5"],
  "Redacción y revisión de contratos": ["M7 4h7l3 3v13H7z", "M14 4v4h4", "M9.5 12h5", "M9.5 15.5h5"],
  "Asesoría legal para empresas": ["M4.5 9h15v10h-15z", "M8 9V6h8v3", "M7 13h10", "M12 12v2"],
  "Constitución y modificación de sociedades": ["M5 19V9l7-4 7 4v10", "M8 19v-6h8v6", "M9 10h.01", "M12 10h.01", "M15 10h.01"],
  "Estudio de títulos": ["M6 4h9l3 3v13H6z", "M15 4v4h4", "M9 12h6", "M9 15.5h6"],
  "Compliance corporativo": ["M12 4l7 4v4.5c0 4.5-3 7.5-7 8.5-4-1-7-4-7-8.5V8z", "M9 12.5l2 2 4-5"],
  "Negociación y resolución de conflictos": ["M6 8h7", "M11 6l3 2-3 2", "M18 16h-7", "M13 14l-3 2 3 2", "M7 19h10"]
};

const paths = iconPaths[title] ?? ["M12 5v14", "M5 12h14"];
---

<article class="group relative flex h-full flex-col overflow-hidden rounded-md border border-slate-200 bg-white p-6 shadow-soft transition duration-300 hover:-translate-y-1 hover:border-gold/70 hover:shadow-[0_26px_70px_rgba(7,26,36,0.14)]">
  <div class="pointer-events-none absolute inset-0 opacity-[0.035] [background-image:linear-gradient(135deg,#0F2D3A_1px,transparent_1px)] [background-size:18px_18px]"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gold/70 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

  <div class="relative flex items-start justify-between gap-5">
    <div class="flex h-12 w-12 items-center justify-center rounded-md border border-petroleum/10 bg-mist text-petroleum transition duration-300 group-hover:-translate-y-0.5 group-hover:border-gold/50 group-hover:bg-night group-hover:text-gold">
      <svg class="h-6 w-6" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
        {paths.map((path) => <path d={path}></path>)}
      </svg>
    </div>
    <span class="rounded-full border border-slate-200 bg-white/80 px-3 py-1 text-[0.65rem] font-bold uppercase tracking-[0.18em] text-slate-400 transition duration-300 group-hover:border-gold/50 group-hover:text-gold">
      Servicio
    </span>
  </div>

  <h3 class="relative mt-6 font-serif text-2xl font-semibold leading-tight text-night">{title}</h3>
  <p class="relative mt-4 flex-1 text-sm leading-7 text-slate-600">{summary}</p>

  <a class="relative mt-7 inline-flex items-center gap-2 text-sm font-bold text-petroleum transition duration-300 group-hover:text-gold" href={href}>
    Revisar este servicio
    <span aria-hidden="true" class="transition duration-300 group-hover:translate-x-1">→</span>
  </a>
</article>
