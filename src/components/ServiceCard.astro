---
type Props = {
  title: string;
  summary: string;
  href: string;
};

const { title, summary, href } = Astro.props;
---

<article class="group relative flex h-full flex-col rounded-md border border-slate-200 bg-white p-6 shadow-soft transition duration-300 hover:-translate-y-1 hover:border-gold/70 hover:shadow-[0_22px_60px_rgba(7,26,36,0.12)]">
  <div class="flex items-start justify-between gap-5">
    <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-gold"></span>
    <span class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400 transition group-hover:text-gold">Servicio</span>
  </div>
  <h3 class="mt-5 font-serif text-2xl font-semibold leading-tight text-night">{title}</h3>
  <p class="mt-4 flex-1 text-sm leading-7 text-slate-600">{summary}</p>
  <a class="mt-7 inline-flex items-center gap-2 text-sm font-bold text-petroleum transition group-hover:text-gold" href={href}>
    Revisar este servicio
    <span aria-hidden="true" class="transition group-hover:translate-x-1">→</span>
  </a>
</article>
