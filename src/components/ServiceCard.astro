---
type Props = {
  title: string;
  summary: string;
  href: string;
};

const { title, summary, href } = Astro.props;
---

<article class="group border-t border-slate-200 py-6 transition hover:border-gold md:px-1">
  <div class="flex gap-5">
    <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-gold"></span>
    <div>
      <h3 class="font-serif text-2xl font-semibold leading-tight text-night">{title}</h3>
      <p class="mt-3 text-sm leading-7 text-slate-600">{summary}</p>
      <a class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-petroleum transition group-hover:text-gold" href={href}>
        Revisar este servicio
        <span aria-hidden="true" class="transition group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</article>
