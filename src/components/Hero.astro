---
import { site } from "@data/site";
---

<section class="bg-white">
  <div class="container-page grid min-h-[calc(100vh-4.75rem)] gap-10 py-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-16">
    <div class="max-w-4xl">
      <p class="eyebrow">San Felipe · Los Andes · Viña del Mar</p>
      <h1 class="mt-5 font-serif text-4xl font-semibold leading-tight tracking-normal text-night sm:text-5xl lg:text-6xl">
        Cancino Abogados | Asesoría legal estratégica para empresas y personas
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-9 text-slate-600">
        Prevenga riesgos, proteja su patrimonio y resuelva conflictos civiles, comerciales, laborales e inmobiliarios con respaldo profesional y comunicación clara.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="btn-primary" href={site.whatsapp} target="_blank" rel="noreferrer">Solicitar evaluación legal</a>
        <a class="btn-outline" href="/contacto/">Contactar a Cancino Abogados</a>
      </div>

      <div class="mt-10 grid gap-0 overflow-hidden rounded-md border border-slate-200 bg-white shadow-soft sm:grid-cols-3">
        {[
          ["Para empresas", "Contratos, riesgos, socios, proveedores y decisiones de administración."],
          ["Para propietarios", "Compraventas, arriendos, títulos, terrenos, parcelas e inmuebles."],
          ["Para empleadores", "Defensa laboral, despidos, finiquitos y prevención de contingencias."]
        ].map(([title, text]) => (
          <div class="border-b border-slate-200 p-5 last:border-b-0 sm:border-b-0 sm:border-r sm:last:border-r-0">
            <p class="text-sm font-bold text-petroleum">{title}</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">{text}</p>
          </div>
        ))}
      </div>
    </div>

    <aside class="relative">
      <div class="absolute -inset-4 rounded-md bg-mist"></div>
      <div class="relative overflow-hidden rounded-md border border-slate-200 bg-night text-white shadow-[0_24px_80px_rgba(7,26,36,0.18)]">
        <div class="grid gap-0 md:grid-cols-[0.9fr_1.1fr] lg:grid-cols-1 xl:grid-cols-[0.86fr_1.14fr]">
          <div class="flex min-h-72 items-center justify-center bg-white/[0.06] p-8">
            <div class="text-center">
              <p class="font-serif text-5xl font-semibold text-gold">SC</p>
              <p class="mt-4 text-sm leading-7 text-white/65">
                Fotografía profesional pendiente de incorporación.
              </p>
            </div>
          </div>
          <div class="p-7 sm:p-8">
            <p class="eyebrow">Abogado director</p>
            <h2 class="mt-3 font-serif text-3xl font-semibold text-white">{site.lawyer.name}</h2>
            <p class="mt-4 text-sm leading-7 text-white/70">{site.lawyer.education}</p>
            <div class="mt-7 space-y-4 border-t border-white/10 pt-6">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">Reconocimiento</p>
                <p class="mt-2 text-sm leading-6 text-white/80">{site.lawyer.recognition}</p>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold">Atención</p>
                <p class="mt-2 text-sm leading-6 text-white/80">Español e inglés, con foco en orientación estratégica.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>
